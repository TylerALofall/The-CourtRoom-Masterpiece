# CourtRoom Masterpiece - Model Router Configuration
# Updated to use kimi-k2-thinking for fast, intelligent routing

# Default model for Ollama runner
MODEL=kimi-k2-thinking:latest

# Alternative heavy model for complex analysis
HEAVY_MODEL=qwen3:latest

# Ollama API endpoint
OLLAMA_BASE=http://127.0.0.1:11434

# GUI Server (for model-to-user messaging)
GUI_PORT=8888

# Notification Hub (for OS notifications)
NOTIFY_PORT=9999

# Data directories
DATA_DIR=./data
LOG_DIR=./data/logs
JSON_DIR=./data/json

# Shared bus for inter-model communication
SHARED_BUS_DIR=./shared_bus
EVIDENCE_CARDS_DIR=./shared_bus/evidence_cards
REFLECTIONS_DIR=./shared_bus/reflections

# Timeouts (seconds)
OLLAMA_TIMEOUT=120
GUI_WAIT_TIMEOUT=60

# Heartbeat settings (set to 0 to disable)
HEARTBEAT_INTERVAL=0
HEARTBEAT_SKIP_IF_BUSY=true

# Reflection settings
REFLECTION_INTERVAL=10
REFLECTION_ENABLED=true

# CSV Log path
CSV_LOG_PATH=./data/logs/actions.csv

# Initialize JSON files for Route 3 (JSON read)
GOALS_FILE=./data/json/goals.json
NOTEPAD_FILE=./data/json/notepad.json
STATUS_FILE=./data/json/status.json

# Ensure directories exist
mkdir -p "$DATA_DIR" "$LOG_DIR" "$JSON_DIR" "$SHARED_BUS_DIR" "$EVIDENCE_CARDS_DIR" "$REFLECTIONS_DIR"

# Initialize JSON files if they don't exist
if [ ! -f "$GOALS_FILE" ]; then echo '{"goals":[]}' > "$GOALS_FILE"; fi
if [ ! -f "$NOTEPAD_FILE" ]; then echo '{"notes":[]}' > "$NOTEPAD_FILE"; fi
if [ ! -f "$STATUS_FILE" ]; then echo '{"status":"idle","last_action":"","epoch_ms":0}' > "$STATUS_FILE"; fi

echo "[CONFIG] Router configured with model: $MODEL"
echo "[CONFIG] Heavy model: $HEAVY_MODEL"
echo "[CONFIG] Reflection enabled: $REFLECTION_ENABLED (every $REFLECTION_INTERVAL actions)"
echo "[CONFIG] CSV log: $CSV_LOG_PATH"
